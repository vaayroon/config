{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug WebServer [https]",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build WebServer Dev",
      "cwd": "${workspaceFolder}/src/WebServer/WebServer",
      "program": "${workspaceFolder}/src/WebServer/WebServer/bin/Debug/net8.0/WebServer.dll",
      "args": [],
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "launchSettingsProfile": "https"
    },
    {
      "name": "Launch Browser (WASM)",
      "type": "blazorwasm",
      "request": "launch",
      "url": "https://localhost:7161",
      "trace": true,
      "timeout": 30000,
      "browser": "chrome"
    }
  ],
  "compounds": [
    {
      "name": "Debug Blazor Web App (Full Stack)",
      "configurations": [
        "Debug WebServer [https]",
        "Launch Browser (WASM)"
      ]
    }
  ]
}