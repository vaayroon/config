// Place your key bindings in this file to override the defaultsauto[]
[
  {
    "key": "shift+alt+s",
    "command": "saveAll"
  },
  {
    "key": "ctrl+k s",
    "command": "-saveAll"
  },
  {
    "key": "ctrl+shift+f9",
    "command": "-o.showOutput"
  },
  {
    "key": "ctrl+shift+f9",
    "command": "workbench.debug.viewlet.action.removeAllBreakpoints"
  },
  {
    "key": "alt+oem_3",
    "command": "-workbench.action.editorDictation.start",
    "when": "hasSpeechProvider && !editorReadonly && !speechToTextInProgress"
  },
  {
    "key": "ctrl+k ctrl+k",
    "command": "-editor.action.defineKeybinding",
    "when": "resource == 'vscode-userdata:/c%3A/Users/condorrb/AppData/Roaming/Code/User/keybindings.json'"
  },
  {
    "key": "ctrl+shift+7",
    "command": "editor.action.commentLine",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "ctrl+oem_2",
    "command": "-editor.action.commentLine",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "alt+oem_3",
    "command": "workbench.files.action.showActiveFileInExplorer"
  },
  {
    "key": "ctrl+i",
    "command": "-emojisense.quickEmoji",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+k ctrl+b",
    "command": "-turboConsoleLog.insertConsoleDebug",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+k ctrl+k",
    "command": "-editor.action.defineKeybinding",
    "when": "resource == 'vscode-userdata:/c%3A/Users/C20734E/AppData/Roaming/Code/User/profiles/555bae99/keybindings.json'"
  },
  {
    "key": "ctrl+k ctrl+k",
    "command": "-turboConsoleLog.insertCustomLog",
    "when": "editorTextFocus"
  },
  {
    "key": "shift+alt+a",
    "command": "editor.action.blockComment",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "ctrl+shift+a",
    "command": "-editor.action.blockComment",
    "when": "editorTextFocus && !editorReadonly"
  }
]