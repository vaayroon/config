{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Clean Bin and Obj Folders (Linux)",
      "type": "shell",
      "command": "find \"${workspaceFolder}\" -type d \\( -name 'bin' -o -name 'obj' \\) -print -exec rm -rf {} +",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": ["-c"]
        }
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "detail": "Remove all bin and obj folders from the workspace directory."
    },
    {
      "label": "Print Bin and Obj Folders (Linux)",
      "type": "shell",
      "command": "find \"${workspaceFolder}\" -type d \\( -name 'bin' -o -name 'obj' \\)",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": ["-c"]
        }
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "detail": "Print all bin and obj folders from the workspace directory."
    },
    {
      "label": "Clean Bin and Obj Folders (Windows)",
      "type": "shell",
      "command": "for /f \"delims=\" %d in ('dir \"${workspaceFolder}\" /ad /s /b ^| findstr /r \"\\\\bin$ \\\\obj$\"') do @echo Eliminando: \"%d\" && rmdir /s /q \"%d\"",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": [
            "/d",
            "/c"
          ]
        }
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "detail": "Remove all bin and obj folders from the workspace directory."
    },
    {
      "label": "Print Bin and Obj Folders (Windows)",
      "type": "shell",
      "command": "for /f \"delims=\" %d in ('dir \"${workspaceFolder}\" /ad /s /b ^| findstr /r \"\\\\bin$ \\\\obj$\"') do @echo \"%d\"",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": [
            "/d",
            "/c"
          ]
        }
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "detail": "Print all bin and obj folders from the workspace directory."
    },
    {
      "label": "Print log given log path (Windows)",
      "detail": "Linux like tailf -f command to print log file content given the log path",
      "type": "shell",
      "command": "powershell -Command \"Get-Content -Path '${input:logPath}' -Wait -Tail 10\"",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": [
            "/d",
            "/c"
          ]
        }
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    }
  ],
  "inputs": [
    {
      "id": "logPath",
      "type": "promptString",
      "description": "Enter the log file path",
      "default": "./splunk.log"
    }
  ]
}